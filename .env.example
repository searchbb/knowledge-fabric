# ===== Core LLM config =====
# Bailian is the default online provider. Generic utility LLM calls inherit
# these settings through app.config.
BAILIAN_API_KEY=your_bailian_api_key_here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL_NAME=qwen3.5-plus
BAILIAN_SEMAPHORE_LIMIT=6
BAILIAN_BATCH_SIZE=1

# Optional OpenAI-compatible override for legacy scripts. Leave unset unless
# you intentionally want to bypass the app's Bailian defaults.
# LLM_API_KEY=${BAILIAN_API_KEY}
# LLM_BASE_URL=${BAILIAN_BASE_URL}
# LLM_MODEL_NAME=${BAILIAN_MODEL_NAME}

# ===== Graph build / Phase 2 extraction =====
# If omitted, Graphiti falls back to the core LLM settings above.
# GRAPHITI_LLM_API_KEY=
# GRAPHITI_LLM_BASE_URL=
# GRAPHITI_LLM_MODEL_NAME=
GRAPHITI_SEMAPHORE_LIMIT=3
GRAPHITI_BATCH_SIZE=3

# ===== Neo4j (local Graphiti backend) =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphiti123

# ===== Legacy Zep compatibility =====
# Keep this if you still want to use the legacy simulation/reporting surfaces.
ZEP_API_KEY=your_zep_api_key_here
ENABLE_LEGACY_ZEP_SIMULATION=true
ENABLE_LEGACY_ZEP_REPORTING=true

# ===== Optional: extraction mode =====
# LLM_MODE_DEFAULT picks which extraction provider to boot with:
#   local   - LM Studio at GRAPHITI_LLM_BASE_URL above
#   bailian - Aliyun DashScope qwen3 series
# Runtime can still switch via PUT /api/config/llm-mode; the
# backend/data/llm_mode.json file persists the last choice.
LLM_MODE_DEFAULT=bailian

# ===== Optional: vault / helper scripts =====
# OBSIDIAN_VAULT_PATH=/absolute/path/to/your/vault
# KNOWLEDGE_WORKSPACE_FRONTEND=http://127.0.0.1:3000
# KNOWLEDGE_WORKSPACE_BACKEND=http://127.0.0.1:5001
# OPENCLAW_FETCH_SCRIPT_PATH=/absolute/path/to/fetch.sh
# OPENCLAW_GATEWAY_LOG=~/.openclaw/logs/gateway.log

# ===== Optional: legacy simulation acceleration =====
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
